<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/crow_bg"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="24dp">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/crow_surface"
            app:navigationIcon="?attr/homeAsUpIndicator"
            app:titleTextColor="@color/crow_accent_yellow" />

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="220dp"
            android:background="@color/crow_surface">

            <androidx.media3.ui.PlayerView
                android:id="@+id/playerView"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                app:show_buffering="when_playing"
                app:surface_type="texture_view"
                app:use_controller="false" />

            <View
                android:id="@+id/enhancementOverlay"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:clickable="false"
                android:focusable="false"
                android:visibility="gone" />
        </FrameLayout>

        <TextView
            android:id="@+id/videoTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="16dp"
            android:paddingTop="12dp"
            android:paddingEnd="16dp"
            android:textColor="@color/crow_on_bg"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/timeLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:textColor="@color/crow_on_muted"
            android:textSize="13sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="horizontal"
            android:paddingTop="8dp">

            <ImageButton
                android:id="@+id/btnPrev"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@null"
                android:src="@android:drawable/ic_media_previous"
                app:tint="@color/crow_accent_yellow" />

            <ImageButton
                android:id="@+id/btnRewind"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@null"
                android:src="@android:drawable/ic_media_rew"
                app:tint="@color/crow_accent_blue" />

            <ImageButton
                android:id="@+id/btnPlayPause"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/play"
                android:src="@android:drawable/ic_media_play"
                app:tint="@color/crow_accent_red" />

            <ImageButton
                android:id="@+id/btnForward"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@null"
                android:src="@android:drawable/ic_media_ff"
                app:tint="@color/crow_accent_blue" />

            <ImageButton
                android:id="@+id/btnNext"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@null"
                android:src="@android:drawable/ic_media_next"
                app:tint="@color/crow_accent_yellow" />

            <ImageButton
                android:id="@+id/btnStop"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/stop"
                android:src="@android:drawable/ic_delete"
                app:tint="@color/crow_on_muted" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="16dp"
            android:paddingTop="16dp"
            android:paddingEnd="16dp"
            android:text="Playback timeline"
            android:textColor="@color/crow_accent_red"
            android:textSize="12sp" />

        <SeekBar
            android:id="@+id/seekPlayback"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp"
            android:max="1000"
            android:progressDrawable="@drawable/seek_playback_progress"
            android:thumbTint="@color/crow_on_bg" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="16dp"
            android:paddingTop="12dp"
            android:paddingEnd="16dp"
            android:text="Trim window (yellow start · blue end)"
            android:textColor="@color/crow_accent_yellow"
            android:textSize="12sp" />

        <SeekBar
            android:id="@+id/seekTrimStart"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp"
            android:max="1000"
            android:progressDrawable="@drawable/seek_trim_progress"
            android:thumbTint="@color/crow_accent_yellow" />

        <SeekBar
            android:id="@+id/seekTrimEnd"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp"
            android:max="1000"
            android:progressDrawable="@drawable/seek_trim_progress"
            android:thumbTint="@color/crow_accent_blue" />

        <TextView
            android:id="@+id/pitchLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="16dp"
            android:paddingTop="16dp"
            android:paddingEnd="16dp"
            android:textColor="@color/crow_on_bg"
            android:textSize="14sp" />

        <SeekBar
            android:id="@+id/seekPitch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp"
            android:max="12"
            android:progress="6"
            android:thumbTint="@color/crow_accent_blue" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingTop="12dp"
            android:paddingEnd="16dp">

            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/switchAutoNext"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/auto_next"
                android:textColor="@color/crow_on_bg"
                app:thumbTint="@color/crow_accent_blue"
                app:trackTint="@color/crow_surface_elevated" />

            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/switchLoop"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/loop"
                android:textColor="@color/crow_on_bg"
                app:thumbTint="@color/crow_accent_blue"
                app:trackTint="@color/crow_surface_elevated" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="16dp"
            android:paddingTop="12dp"
            android:paddingEnd="16dp"
            android:text="Visual enhancement (simulated)"
            android:textColor="@color/crow_accent_blue"
            android:textSize="12sp" />

        <Spinner
            android:id="@+id/spinnerEnhancement"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="12dp"
            android:padding="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="horizontal"
            android:padding="16dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnFavorite"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:layout_weight="1"
                android:text="@string/favorite_on"
                app:strokeColor="@color/crow_accent_yellow" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSavePrefs"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/save_prefs"
                app:backgroundTint="@color/crow_accent_blue" />
        </LinearLayout>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
